# Per-deploy environment variables.
# Set these in Railway's "Variables" tab when creating a new service from this template.
# Do NOT commit a real .env file with values.

# --- Required: select an LLM provider ---
# Codex OAuth (this template's default): no API key here — auth tokens are
# obtained via `hermes auth login openai-codex` and written to /data/auth.json.
HERMES_INFERENCE_PROVIDER=openai-codex

# To use a different provider, unset HERMES_INFERENCE_PROVIDER and set one of:
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OLLAMA_API_KEY=          # Ollama Cloud
# (Self-hosted Ollama: OPENAI_BASE_URL=http://your-host:11434/v1 + OPENAI_API_KEY=ollama)

# --- Required: at least one chat channel ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=          # your numeric Telegram user ID; comma-separated for multiple
TELEGRAM_HOME_CHANNEL=           # chat ID where Hermes sends proactive/cron messages

# Optional alternatives:
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# --- Recommended ---
HERMES_TIMEZONE=Europe/London    # IANA timezone; affects cron and time-aware behaviour

# --- Internal API server (used by the workspace service in Wave 2) ---
# These are already defaulted in the Dockerfile; only override if needed.
# API_SERVER_ENABLED=true
# API_SERVER_HOST=0.0.0.0
# API_SERVER_PORT=8642
HERMES_API_TOKEN=                # bearer token the workspace will use to authenticate
